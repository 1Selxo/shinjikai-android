    <string name="intro_page_1_eyebrow">الخطوة 1</string>
    <string name="intro_page_1_title">ابحث بالطريقة التي تناسبك</string>
    <string name="intro_page_1_body">اكتب باليابانية أو بالعربية أو بالرومـاجي، ثم تنقّل بين النتائج بسرعة حتى تصل إلى الكلمة التي تريدها.</string>
